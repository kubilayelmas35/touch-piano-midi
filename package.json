{
  "name": "touch-piano-midi",
  "version": "1.1.0",
  "description": "Dokunmatik piyano, gitar, keman — MIDI düşen notalar",
  "main": "electron/main.js",
  "scripts": {
    "bundle": "node scripts/bundle-renderer.js",
    "prestart": "node scripts/bundle-renderer.js",
    "start": "electron .",
    "pack": "electron-builder --win portable"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28"
  },
  "build": {
    "appId": "com.touchpiano.midi",
    "productName": "Touch Piano MIDI",
    "directories": {
      "output": "dist"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": ["portable"]
    },
    "files": ["electron/**/*", "src/**/*", "package.json"]
  }
}
